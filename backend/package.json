{
  "name": "backend",
  "version": "4.0.1",
  "author": "seeeroy",
  "private": true,
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "cross-env NODE_ENV=development nest start --watch --exec 'bun -r tsconfig-paths/register -r ts-node/register ./src/main.ts'",
    "start:debug": "nest start --debug --watch",
    "start:prod": "bun dist/backend/src/main",
    "openapi:json": "bun -r tsconfig-paths/register ./scripts/generate-openapi.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.2",
    "@grammyjs/ratelimiter": "^1.2.1",
    "@grammyjs/runner": "^2.0.3",
    "@hloth/minecraft-query": "^1.0.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/platform-socket.io": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/websockets": "^11.1.27",
    "@scalar/nestjs-api-reference": "^1.2.4",
    "@xhmikosr/decompress": "^10.2.1",
    "@xterm/headless": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bun-types": "^1.3.14",
    "chalk": "^5.6.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "compressing": "^2.1.1",
    "dockerode": "^5.0.0",
    "ftpd": "^0.2.16",
    "grammy": "^1.44.0",
    "jimp": "^1.6.1",
    "ky": "^1.14.3",
    "mime-types": "^3.0.2",
    "minecraft-server-properties": "^1.0.0",
    "multer": "^2.2.0",
    "node-machine-id": "^1.1.12",
    "ora": "^9.4.0",
    "os-utils": "^0.0.14",
    "otplib": "^13.4.1",
    "pidusage": "^4.0.1",
    "public-ip": "7.0.1",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@kubekpanel/blueprint-sdk": "^0.2.0",
    "@kubekpanel/extension-sdk": "^0.1.1",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "^1.3.14",
    "@types/chalk": "^2.2.4",
    "@types/dockerode": "^4.0.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.13.2",
    "@types/os-utils": "^0.0.4",
    "@types/public-ip": "^3.1.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^11.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^16.5.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "socket.io-client": "^4.8.3",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
